<Window
    x:Class="Hutao.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Hutao"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Snap.Hutao.Remastered.Deployment">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" 
              Grid.Row="0"
              Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
              Padding="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧Logo -->
            <Image Grid.Column="0"
                   Source="ms-appx:///Assets/InAppLogo.png"
                   Width="128"
                   Height="128"
                   VerticalAlignment="Top"
                   Margin="0,2,12,0"/>

            <!-- 右侧信息面板 -->
            <StackPanel Grid.Column="1" 
                        VerticalAlignment="Center"
                        Spacing="6">

                <!-- 应用标题 -->
                <TextBlock x:Name="tbAppTitle"
                           Text="Snap.Hutao Remastered Installer"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"/>

                <!-- 发布者信息 -->
                <TextBlock Text="发布者: Snap.Hutao Remastering Project"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           FontSize="12"/>

                <!-- 版本信息行 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="本地版本: " 
                                   FontWeight="SemiBold"
                                   FontSize="13"/>
                        <TextBlock x:Name="tbLocalVersion" 
                                   Text="未安装"
                                   FontSize="13"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal"
                                Margin="24,0,0,0">
                        <TextBlock Text="最新版本: " 
                                   FontWeight="SemiBold"
                                   FontSize="13"/>
                        <TextBlock x:Name="tbLatestVersion" 
                                   Text="正在获取..."
                                   FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- 状态行 -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="状态: " 
                               FontWeight="SemiBold"
                               FontSize="13"/>
                    <TextBlock x:Name="tbStatus" 
                               Text="正在检查更新..."
                               FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" 
              Padding="16,12,16,8"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <!-- 第一行：进度区域（自动高度，可折叠） -->
                <RowDefinition Height="Auto"/>
                <!-- 第二行：占满剩余空间，按钮置于该行右下角 -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 进度显示区域（默认折叠） -->
            <Border Grid.Row="0"
                    x:Name="progressArea"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="12,8"
                    Margin="0,0,0,16"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="tbProgressTitle"
                               Text="正在下载..."
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <ProgressBar x:Name="pbProgress"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Height="6"
                                 Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   x:Name="tbProgressText"
                                   Text="0%"
                                   FontSize="11"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="tbProgressSpeed"
                                   Text=""
                                   FontSize="11"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,0">
                <Button x:Name="btnAction"
                        Content="检查更新"
                        Click="btnAction_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        MinWidth="100"
                        Height="32"
                        Padding="12,0"/>
                <Button x:Name="btnCancel"
                        Content="取消"
                        Click="btnCancel_Click"
                        Margin="8,0,0,0"
                        MinWidth="70"
                        Height="32"
                        Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <TextBlock x:Name="tbFooter"
                       Text="Snap.Hutao.Remastered Deployment v1.0.1"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"/>
        </Border>
    </Grid>
</Window>